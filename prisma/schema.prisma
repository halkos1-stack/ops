generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SystemRole {
  SUPER_ADMIN
  USER
}

enum OrganizationRole {
  ORG_ADMIN
  MANAGER
  PARTNER
}

enum BookingSyncStatus {
  PENDING_MATCH
  READY_FOR_ACTION
  CANCELLED
  ERROR
}

enum BookingMappingStatus {
  ACTIVE
  INACTIVE
}

enum PropertyReadinessStatus {
  READY      @map("ready")
  BORDERLINE @map("borderline")
  NOT_READY  @map("not_ready")
  UNKNOWN    @map("unknown")
}

enum PropertyConditionType {
  SUPPLY @map("supply")
  ISSUE  @map("issue")
  DAMAGE @map("damage")
}

enum PropertyConditionStatus {
  OPEN       @map("open")
  MONITORING @map("monitoring")
  RESOLVED   @map("resolved")
  DISMISSED  @map("dismissed")
}

enum PropertyConditionBlockingStatus {
  BLOCKING     @map("blocking")
  NON_BLOCKING @map("non_blocking")
  WARNING      @map("warning")
}

enum PropertyConditionSeverity {
  LOW      @map("low")
  MEDIUM   @map("medium")
  HIGH     @map("high")
  CRITICAL @map("critical")
}

enum PropertyConditionManagerDecision {
  ALLOW_WITH_ISSUE     @map("allow_with_issue")
  BLOCK_UNTIL_RESOLVED @map("block_until_resolved")
  MONITOR              @map("monitor")
  RESOLVED             @map("resolved")
  DISMISSED            @map("dismissed")
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  systemRole    SystemRole @default(USER)
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts         Account[]
  sessions         Session[]
  memberships      Membership[]
  activationTokens UserActivationToken[]
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships        Membership[]
  properties         Property[]
  bookings           Booking[]
  bookingMappings    BookingPropertyMapping[]
  bookingSyncEvents  BookingSyncEvent[]
  partners           Partner[]
  tasks              Task[]
  issues             Issue[]
  propertyConditions PropertyCondition[]
  events             Event[]
  checklistTemplates PropertyChecklistTemplate[]
  issueTemplates     PropertyIssueTemplate[]
  activityLogs       ActivityLog[]
  settings           Settings[]
  qrCodes            PropertySupplyQRCode[]
}

model Membership {
  id                String           @id @default(cuid())
  userId            String
  organizationId    String
  role              OrganizationRole
  isActive          Boolean          @default(true)
  isPrimaryOrgAdmin Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
  @@index([organizationId, isPrimaryOrgAdmin])
}

model Property {
  id                         String                   @id @default(cuid())
  organizationId             String
  code                       String
  name                       String
  address                    String
  city                       String
  region                     String
  postalCode                 String
  country                    String
  type                       String
  status                     String
  bedrooms                   Int                      @default(0)
  bathrooms                  Int                      @default(0)
  maxGuests                  Int                      @default(0)
  notes                      String?
  defaultPartnerId           String?
  readinessStatus            PropertyReadinessStatus?
  readinessUpdatedAt         DateTime?
  readinessReasonsText       String?
  openConditionCount         Int                      @default(0)
  openBlockingConditionCount Int                      @default(0)
  openWarningConditionCount  Int                      @default(0)
  nextCheckInAt              DateTime?
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt

  organization       Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  defaultPartner     Partner?                    @relation("PropertyDefaultPartner", fields: [defaultPartnerId], references: [id], onDelete: SetNull)
  bookings           Booking[]
  bookingMappings    BookingPropertyMapping[]
  tasks              Task[]
  checklistTemplates PropertyChecklistTemplate[]
  issueTemplates     PropertyIssueTemplate[]
  issues             Issue[]
  conditions         PropertyCondition[]
  propertySupplies   PropertySupply[]
  taskPhotos         TaskPhoto[]
  activityLogs       ActivityLog[]
  events             Event[]
  qrCodes            PropertySupplyQRCode[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([defaultPartnerId])
  @@index([status])
  @@index([name])
  @@index([readinessStatus])
  @@index([nextCheckInAt])
  @@index([organizationId, readinessStatus])
}

model PropertyCondition {
  id               String                          @id @default(cuid())
  organizationId   String
  propertyId       String
  taskId           String?
  bookingId        String?
  propertySupplyId String?
  mergeKey         String?
  sourceType       String                          @default("system")
  sourceLabel      String?
  sourceItemId     String?
  sourceItemLabel  String?
  sourceRunId      String?
  sourceAnswerId   String?
  conditionType    PropertyConditionType
  title            String
  description      String?
  locationText     String?
  status           PropertyConditionStatus         @default(OPEN)
  blockingStatus   PropertyConditionBlockingStatus @default(WARNING)
  severity         PropertyConditionSeverity       @default(MEDIUM)
  managerDecision  PropertyConditionManagerDecision?
  managerNotes     String?
  evidence         Json?
  firstDetectedAt  DateTime                        @default(now())
  lastDetectedAt   DateTime                        @default(now())
  resolvedAt       DateTime?
  dismissedAt      DateTime?
  createdAt        DateTime                        @default(now())
  updatedAt        DateTime                        @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property       Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  task           Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)
  booking        Booking?        @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  propertySupply PropertySupply? @relation(fields: [propertySupplyId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([propertyId])
  @@index([taskId])
  @@index([bookingId])
  @@index([propertySupplyId])
  @@index([mergeKey])
  @@index([conditionType])
  @@index([status])
  @@index([blockingStatus])
  @@index([severity])
  @@index([managerDecision])
  @@index([propertyId, status])
  @@index([propertyId, blockingStatus])
  @@index([propertyId, conditionType])
  @@index([propertyId, createdAt])
  @@index([propertyId, mergeKey])
}

model Booking {
  id                         String            @id @default(cuid())
  organizationId             String
  propertyId                 String?
  sourcePlatform             String
  externalBookingId          String
  externalListingId          String?
  externalListingName        String?
  externalPropertyAddress    String?
  externalPropertyCity       String?
  externalPropertyRegion     String?
  externalPropertyPostalCode String?
  externalPropertyCountry    String?
  guestName                  String?
  guestPhone                 String?
  guestEmail                 String?
  checkInDate                DateTime
  checkOutDate               DateTime
  checkInTime                String?
  checkOutTime               String?
  adults                     Int               @default(1)
  children                   Int               @default(0)
  infants                    Int               @default(0)
  status                     String            @default("confirmed")
  syncStatus                 BookingSyncStatus @default(PENDING_MATCH)
  needsMapping               Boolean           @default(true)
  isManual                   Boolean           @default(false)
  sourceUpdatedAt            DateTime?
  rawPayload                 Json?
  lastProcessedAt            DateTime?
  lastError                  String?
  notes                      String?
  importedAt                 DateTime          @default(now())
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property           Property?           @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  tasks              Task[]
  issues             Issue[]
  propertyConditions PropertyCondition[]
  activityLogs       ActivityLog[]
  events             Event[]
  syncEvents         BookingSyncEvent[]

  @@unique([organizationId, sourcePlatform, externalBookingId])
  @@index([organizationId])
  @@index([propertyId])
  @@index([sourcePlatform])
  @@index([status])
  @@index([syncStatus])
  @@index([needsMapping])
  @@index([externalListingId])
  @@index([checkInDate])
  @@index([checkOutDate])
  @@index([organizationId, propertyId, checkOutDate])
}

model BookingPropertyMapping {
  id                  String               @id @default(cuid())
  organizationId      String
  propertyId          String
  sourcePlatform      String
  externalListingId   String
  externalListingName String?
  status              BookingMappingStatus @default(ACTIVE)
  notes               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property     Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([organizationId, sourcePlatform, externalListingId])
  @@index([organizationId])
  @@index([propertyId])
  @@index([sourcePlatform])
  @@index([status])
  @@index([externalListingId])
}

model BookingSyncEvent {
  id             String             @id @default(cuid())
  bookingId      String
  organizationId String
  eventType      String
  sourcePlatform String
  resultStatus   BookingSyncStatus?
  message        String?
  payload        Json?
  createdAt      DateTime           @default(now())

  booking      Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([organizationId])
  @@index([sourcePlatform])
  @@index([eventType])
  @@index([resultStatus])
  @@index([createdAt])
}

model Partner {
  id             String   @id @default(cuid())
  organizationId String
  code           String
  name           String
  email          String
  phone          String?
  specialty      String
  status         String   @default("active")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization       Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  defaultProperties  Property[]                 @relation("PropertyDefaultPartner")
  taskAssignments    TaskAssignment[]
  activityLogs       ActivityLog[]
  events             Event[]
  portalAccessTokens PartnerPortalAccessToken[]

  @@unique([organizationId, code])
  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([status])
  @@index([specialty])
  @@index([name])
}

model PartnerPortalAccessToken {
  id         String    @id @default(cuid())
  partnerId  String
  token      String    @unique
  isActive   Boolean   @default(true)
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@index([token])
  @@index([isActive])
  @@index([expiresAt])
}

model Task {
  id                              String    @id @default(cuid())
  organizationId                  String
  propertyId                      String
  bookingId                       String?
  title                           String
  description                     String?
  taskType                        String
  source                          String    @default("manual")
  priority                        String    @default("normal")
  status                          String    @default("pending")
  scheduledDate                   DateTime
  scheduledStartTime              String?
  scheduledEndTime                String?
  dueDate                         DateTime?
  completedAt                     DateTime?
  requiresPhotos                  Boolean   @default(false)
  requiresChecklist               Boolean   @default(false)
  requiresApproval                Boolean   @default(false)
  sendCleaningChecklist           Boolean   @default(true)
  sendSuppliesChecklist           Boolean   @default(false)
  sendIssuesChecklist             Boolean   @default(false)
  usesCustomizedCleaningChecklist Boolean   @default(false)
  usesCustomizedSuppliesChecklist Boolean   @default(false)
  usesCustomizedIssuesChecklist   Boolean   @default(false)
  alertEnabled                    Boolean   @default(false)
  alertAt                         DateTime?
  notes                           String?
  resultNotes                     String?
  createdAt                       DateTime  @default(now())
  updatedAt                       DateTime  @updatedAt

  organization       Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property           Property               @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  booking            Booking?               @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  assignments        TaskAssignment[]
  issues             Issue[]
  propertyConditions PropertyCondition[]
  taskPhotos         TaskPhoto[]
  supplyConsumptions SupplyConsumption[]
  activityLogs       ActivityLog[]
  checklistRun       TaskChecklistRun?
  supplyRun          TaskSupplyRun?
  issueRun           TaskIssueRun?
  events             Event[]
  qrScans            PropertySupplyQRScan[]

  @@index([organizationId])
  @@index([propertyId])
  @@index([bookingId])
  @@index([status])
  @@index([taskType])
  @@index([source])
  @@index([priority])
  @@index([scheduledDate])
  @@index([alertEnabled])
  @@index([alertAt])
}

model TaskAssignment {
  id                      String    @id @default(cuid())
  taskId                  String
  partnerId               String
  assignedAt              DateTime  @default(now())
  acceptedAt              DateTime?
  rejectedAt              DateTime?
  startedAt               DateTime?
  completedAt             DateTime?
  status                  String    @default("assigned")
  rejectionReason         String?
  notes                   String?
  responseToken           String?   @unique
  responseTokenExpiresAt  DateTime?
  checklistToken          String?   @unique
  checklistTokenExpiresAt DateTime?
  assignmentEmailSentAt   DateTime?
  checklistEmailSentAt    DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  task    Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([partnerId])
  @@index([status])
}

model Issue {
  id                      String    @id @default(cuid())
  organizationId          String
  propertyId              String
  taskId                  String?
  bookingId               String?
  issueType               String
  title                   String
  description             String?
  severity                String    @default("medium")
  status                  String    @default("open")
  reportedBy              String?
  affectsHosting          Boolean   @default(false)
  requiresImmediateAction Boolean   @default(false)
  locationText            String?
  resolutionNotes         String?
  resolvedAt              DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  task         Task?         @relation(fields: [taskId], references: [id], onDelete: SetNull)
  booking      Booking?      @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  taskPhotos   TaskPhoto[]
  activityLogs ActivityLog[]
  events       Event[]

  @@index([organizationId])
  @@index([propertyId])
  @@index([taskId])
  @@index([bookingId])
  @@index([issueType])
  @@index([severity])
  @@index([status])
  @@index([affectsHosting])
  @@index([requiresImmediateAction])
}

model SupplyItem {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  nameEl       String?
  nameEn       String?
  category     String
  unit         String
  minimumStock Float?   @default(0)
  isActive     Boolean  @default(true)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  propertySupplies       PropertySupply[]
  consumptions           SupplyConsumption[]
  checklistTemplateItems PropertyChecklistTemplateItem[]
  taskChecklistRunItems  TaskChecklistRunItem[]
  taskSupplyRunItems     TaskSupplyRunItem[]

  @@index([category])
  @@index([isActive])
  @@index([name])
  @@index([nameEl])
  @@index([nameEn])
}

model PropertySupply {
  id               String   @id @default(cuid())
  propertyId       String
  supplyItemId     String
  isActive         Boolean  @default(true)
  fillLevel        String   @default("full")
  currentStock     Float    @default(0)
  targetStock      Float?
  reorderThreshold Float?
  targetLevel      Float?
  minimumThreshold Float?
  trackingMode     String   @default("fill_level")
  isCritical       Boolean  @default(false)
  warningThreshold Float?
  lastUpdatedAt    DateTime @default(now())
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  property           Property               @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  supplyItem         SupplyItem             @relation(fields: [supplyItemId], references: [id], onDelete: Cascade)
  taskSupplyRunItems TaskSupplyRunItem[]
  taskSupplyAnswers  TaskSupplyAnswer[]
  propertyConditions PropertyCondition[]
  qrCodes            PropertySupplyQRCode[]

  @@unique([propertyId, supplyItemId])
  @@index([propertyId])
  @@index([supplyItemId])
  @@index([isActive])
  @@index([fillLevel])
  @@index([trackingMode])
  @@index([isCritical])
}

model SupplyConsumption {
  id           String   @id @default(cuid())
  taskId       String
  supplyItemId String
  quantity     Float
  unit         String
  notes        String?
  createdAt    DateTime @default(now())

  task       Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  supplyItem SupplyItem @relation(fields: [supplyItemId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([supplyItemId])
}

model TaskPhoto {
  id         String   @id @default(cuid())
  propertyId String
  taskId     String?
  issueId    String?
  category   String
  fileUrl    String
  fileName   String?
  caption    String?
  takenAt    DateTime?
  uploadedAt DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  task     Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  issue    Issue?   @relation(fields: [issueId], references: [id], onDelete: SetNull)

  @@index([propertyId])
  @@index([taskId])
  @@index([issueId])
  @@index([category])
}

model PropertyChecklistTemplate {
  id             String   @id @default(cuid())
  organizationId String
  propertyId     String
  title          String
  description    String?
  templateType   String   @default("main")
  isPrimary      Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property      Property                  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  items         PropertyChecklistTemplateItem[]
  checklistRuns TaskChecklistRun[]

  @@index([organizationId])
  @@index([propertyId])
  @@index([propertyId, templateType])
  @@index([propertyId, isPrimary])
}

model PropertyChecklistTemplateItem {
  id               String  @id @default(cuid())
  templateId       String
  label            String
  labelEn          String?
  description      String?
  itemType         String
  isRequired       Boolean @default(true)
  sortOrder        Int
  category         String? @default("inspection")
  requiresPhoto    Boolean @default(false)
  opensIssueOnFail Boolean @default(false)
  optionsText      String?

  issueTypeOnFail     String? @default("repair")
  issueSeverityOnFail String? @default("medium")
  failureValuesText   String?

  linkedSupplyItemId String?
  supplyUpdateMode   String @default("none")
  supplyQuantity     Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  template             PropertyChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  runItems             TaskChecklistRunItem[]
  taskChecklistAnswers TaskChecklistAnswer[]
  supplyItem           SupplyItem?               @relation(fields: [linkedSupplyItemId], references: [id], onDelete: SetNull)

  @@index([templateId])
  @@index([templateId, sortOrder])
  @@index([linkedSupplyItemId])
  @@index([supplyUpdateMode])
}

model TaskChecklistRun {
  id                        String   @id @default(cuid())
  taskId                    String   @unique
  templateId                String?
  sourceTemplateTitle       String?
  sourceTemplateDescription String?
  templateType              String?  @default("main")
  isCustomized              Boolean  @default(false)
  status                    String   @default("pending")
  startedAt                 DateTime?
  completedAt               DateTime?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  task     Task                       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  template PropertyChecklistTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  items    TaskChecklistRunItem[]
  answers  TaskChecklistAnswer[]

  @@index([templateId])
  @@index([status])
  @@index([isCustomized])
}

model TaskChecklistRunItem {
  id                     String   @id @default(cuid())
  checklistRunId         String
  propertyTemplateItemId String?
  label                  String
  labelEn                String?
  description            String?
  itemType               String
  isRequired             Boolean  @default(true)
  sortOrder              Int
  category               String?  @default("inspection")
  requiresPhoto          Boolean  @default(false)
  opensIssueOnFail       Boolean  @default(false)
  optionsText            String?
  issueTypeOnFail        String?  @default("repair")
  issueSeverityOnFail    String?  @default("medium")
  failureValuesText      String?
  linkedSupplyItemId     String?
  linkedSupplyItemName   String?
  linkedSupplyItemNameEl String?
  linkedSupplyItemNameEn String?
  supplyUpdateMode       String   @default("none")
  supplyQuantity         Float?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  checklistRun         TaskChecklistRun              @relation(fields: [checklistRunId], references: [id], onDelete: Cascade)
  propertyTemplateItem PropertyChecklistTemplateItem? @relation(fields: [propertyTemplateItemId], references: [id], onDelete: SetNull)
  supplyItem           SupplyItem?                   @relation(fields: [linkedSupplyItemId], references: [id], onDelete: SetNull)
  answers              TaskChecklistAnswer[]

  @@index([checklistRunId])
  @@index([checklistRunId, sortOrder])
  @@index([propertyTemplateItemId])
  @@index([linkedSupplyItemId])
}

model TaskChecklistAnswer {
  id             String   @id @default(cuid())
  checklistRunId String
  runItemId      String
  templateItemId String?
  valueBoolean   Boolean?
  valueText      String?
  valueNumber    Float?
  valueSelect    String?
  notes          String?
  photoUrls      Json?
  issueCreated   Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  checklistRun TaskChecklistRun              @relation(fields: [checklistRunId], references: [id], onDelete: Cascade)
  runItem      TaskChecklistRunItem          @relation(fields: [runItemId], references: [id], onDelete: Cascade)
  templateItem PropertyChecklistTemplateItem? @relation(fields: [templateItemId], references: [id], onDelete: SetNull)

  @@index([checklistRunId])
  @@index([runItemId])
  @@index([templateItemId])
}

model PropertyIssueTemplate {
  id             String   @id @default(cuid())
  organizationId String
  propertyId     String
  title          String
  description    String?
  isPrimary      Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property     Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  items        PropertyIssueTemplateItem[]
  issueRuns    TaskIssueRun[]

  @@index([organizationId])
  @@index([propertyId])
  @@index([propertyId, isPrimary])
  @@index([propertyId, isActive])
}

model PropertyIssueTemplateItem {
  id                      String   @id @default(cuid())
  templateId              String
  label                   String
  labelEn                 String?
  description             String?
  sortOrder               Int
  itemType                String   @default("issue_check")
  isRequired              Boolean  @default(true)
  allowsIssue             Boolean  @default(true)
  allowsDamage            Boolean  @default(true)
  defaultIssueType        String?  @default("repair")
  defaultSeverity         String?  @default("medium")
  requiresPhoto           Boolean  @default(false)
  affectsHostingByDefault Boolean  @default(false)
  urgentByDefault         Boolean  @default(false)
  locationHint            String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  template         PropertyIssueTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  runItems         TaskIssueRunItem[]
  taskIssueAnswers TaskIssueAnswer[]

  @@index([templateId])
  @@index([templateId, sortOrder])
}

model TaskIssueRun {
  id                        String   @id @default(cuid())
  taskId                    String   @unique
  templateId                String?
  sourceTemplateTitle       String?
  sourceTemplateDescription String?
  isCustomized              Boolean  @default(false)
  status                    String   @default("pending")
  startedAt                 DateTime?
  completedAt               DateTime?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  task     Task                   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  template PropertyIssueTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  items    TaskIssueRunItem[]
  answers  TaskIssueAnswer[]

  @@index([templateId])
  @@index([status])
  @@index([isCustomized])
}

model TaskIssueRunItem {
  id                     String   @id @default(cuid())
  issueRunId             String
  propertyTemplateItemId String?
  label                  String
  labelEn                String?
  description            String?
  sortOrder              Int
  itemType               String   @default("issue_check")
  isRequired             Boolean  @default(true)
  allowsIssue            Boolean  @default(true)
  allowsDamage           Boolean  @default(true)
  defaultIssueType       String?  @default("repair")
  defaultSeverity        String?  @default("medium")
  requiresPhoto          Boolean  @default(false)
  affectsHostingByDefault Boolean @default(false)
  urgentByDefault        Boolean  @default(false)
  locationHint           String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  issueRun             TaskIssueRun               @relation(fields: [issueRunId], references: [id], onDelete: Cascade)
  propertyTemplateItem PropertyIssueTemplateItem? @relation(fields: [propertyTemplateItemId], references: [id], onDelete: SetNull)
  answers              TaskIssueAnswer[]

  @@index([issueRunId])
  @@index([issueRunId, sortOrder])
  @@index([propertyTemplateItemId])
}

model TaskIssueAnswer {
  id                      String   @id @default(cuid())
  issueRunId              String
  runItemId               String
  templateItemId          String?
  reportType              String?
  title                   String?
  description             String?
  severity                String?
  affectsHosting          Boolean?
  requiresImmediateAction Boolean?
  locationText            String?
  photoUrls               Json?
  createdIssueId          String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  issueRun     TaskIssueRun               @relation(fields: [issueRunId], references: [id], onDelete: Cascade)
  runItem      TaskIssueRunItem           @relation(fields: [runItemId], references: [id], onDelete: Cascade)
  templateItem PropertyIssueTemplateItem? @relation(fields: [templateItemId], references: [id], onDelete: SetNull)

  @@index([issueRunId])
  @@index([runItemId])
  @@index([templateItemId])
  @@index([createdIssueId])
}

model TaskSupplyRun {
  id           String   @id @default(cuid())
  taskId       String   @unique
  isCustomized Boolean  @default(false)
  status       String   @default("pending")
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  task    Task              @relation(fields: [taskId], references: [id], onDelete: Cascade)
  items   TaskSupplyRunItem[]
  answers TaskSupplyAnswer[]

  @@index([status])
  @@index([isCustomized])
}

model TaskSupplyRunItem {
  id               String   @id @default(cuid())
  taskSupplyRunId  String
  propertySupplyId String?
  supplyItemId     String?
  propertySupplyCode String?
  label            String
  labelEn          String?
  category         String?
  unit             String?
  fillLevel        String?
  currentStock     Float?
  targetStock      Float?
  reorderThreshold Float?
  targetLevel      Float?
  minimumThreshold Float?
  trackingMode     String   @default("fill_level")
  isCritical       Boolean  @default(false)
  warningThreshold Float?
  sortOrder        Int
  isRequired       Boolean  @default(true)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  taskSupplyRun  TaskSupplyRun   @relation(fields: [taskSupplyRunId], references: [id], onDelete: Cascade)
  propertySupply PropertySupply? @relation(fields: [propertySupplyId], references: [id], onDelete: SetNull)
  supplyItem     SupplyItem?     @relation(fields: [supplyItemId], references: [id], onDelete: SetNull)
  answers        TaskSupplyAnswer[]

  @@index([taskSupplyRunId])
  @@index([taskSupplyRunId, sortOrder])
  @@index([propertySupplyId])
  @@index([supplyItemId])
}

model TaskSupplyAnswer {
  id               String   @id @default(cuid())
  taskSupplyRunId  String
  runItemId        String
  propertySupplyId String?
  fillLevel        String
  quantityValue    Float?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  taskSupplyRun  TaskSupplyRun   @relation(fields: [taskSupplyRunId], references: [id], onDelete: Cascade)
  runItem        TaskSupplyRunItem @relation(fields: [runItemId], references: [id], onDelete: Cascade)
  propertySupply PropertySupply? @relation(fields: [propertySupplyId], references: [id], onDelete: SetNull)

  @@unique([taskSupplyRunId, runItemId])
  @@index([taskSupplyRunId])
  @@index([runItemId])
  @@index([propertySupplyId])
  @@index([fillLevel])
}

model Event {
  id             String   @id @default(cuid())
  organizationId String
  propertyId     String?
  bookingId      String?
  taskId         String?
  issueId        String?
  partnerId      String?
  title          String
  description    String?
  eventType      String
  status         String   @default("open")
  startAt        DateTime?
  endAt          DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property     Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  booking      Booking?     @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  task         Task?        @relation(fields: [taskId], references: [id], onDelete: SetNull)
  issue        Issue?       @relation(fields: [issueId], references: [id], onDelete: SetNull)
  partner      Partner?     @relation(fields: [partnerId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([propertyId])
  @@index([bookingId])
  @@index([taskId])
  @@index([issueId])
  @@index([partnerId])
  @@index([eventType])
  @@index([status])
  @@index([startAt])
}

model ActivityLog {
  id             String   @id @default(cuid())
  organizationId String
  propertyId     String?
  bookingId      String?
  taskId         String?
  issueId        String?
  partnerId      String?
  entityType     String
  entityId       String
  action         String
  message        String?
  actorType      String?
  actorName      String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property     Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  booking      Booking?     @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  task         Task?        @relation(fields: [taskId], references: [id], onDelete: SetNull)
  issue        Issue?       @relation(fields: [issueId], references: [id], onDelete: SetNull)
  partner      Partner?     @relation(fields: [partnerId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([propertyId])
  @@index([bookingId])
  @@index([taskId])
  @@index([issueId])
  @@index([partnerId])
  @@index([entityType])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
}

model Settings {
  id                   String   @id @default(cuid())
  organizationId       String
  companyName          String
  companyEmail         String
  companyPhone         String   @default("")
  companyAddress       String   @default("")
  defaultTaskStatus    String   @default("pending")
  defaultPartnerStatus String   @default("active")
  timezone             String   @default("Europe/Athens")
  language             String   @default("el")
  notificationsEnabled Boolean  @default(true)
  calendarDefaultView  String   @default("month")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId])
  @@index([organizationId])
}

model Account {
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? @db.Text
  session_state            String?
  refresh_token_expires_in Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model UserActivationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@index([usedAt])
}

model PropertySupplyQRCode {
  id               String   @id @default(cuid())
  organizationId   String
  propertyId       String
  propertySupplyId String
  code             String   @unique
  label            String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property       Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertySupply PropertySupply @relation(fields: [propertySupplyId], references: [id], onDelete: Cascade)
  scans          PropertySupplyQRScan[]

  @@index([organizationId])
  @@index([propertyId])
  @@index([propertySupplyId])
  @@index([code])
  @@index([isActive])
}

model PropertySupplyQRScan {
  id        String   @id @default(cuid())
  qrCodeId  String
  taskId    String?
  scannedBy String?
  fillLevel String?
  notes     String?
  scannedAt DateTime @default(now())

  qrCode PropertySupplyQRCode @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  task   Task?                @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([qrCodeId])
  @@index([taskId])
  @@index([scannedAt])
}